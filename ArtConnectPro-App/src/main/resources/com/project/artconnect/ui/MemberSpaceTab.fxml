<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.MemberSpaceController">
    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Profil"/>
        <ComboBox fx:id="memberSelector" prefWidth="260.0"/>
        <Button text="Actualiser" onAction="#handleRefresh"/>
    </HBox>

    <GridPane hgap="10.0" vgap="8.0">
        <Label text="Nom" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Email" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <TextField fx:id="emailField" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
        <Label text="Ville" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="cityField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="Adhesion" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <TextField fx:id="membershipField" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
        <Button fx:id="saveProfileButton" text="Enregistrer le profil" onAction="#handleSaveProfile" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
    </GridPane>

    <Separator/>

    <HBox spacing="18.0" VBox.vgrow="ALWAYS">
        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
            <Label text="Reservations"/>
            <HBox spacing="10.0">
                <ComboBox fx:id="workshopSelector" promptText="Atelier" HBox.hgrow="ALWAYS"/>
                <Button fx:id="bookWorkshopButton" text="Reserver" onAction="#handleBookWorkshop"/>
            </HBox>
            <ListView fx:id="bookingList" VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
            <Label text="Avis"/>
            <ComboBox fx:id="artworkSelector" promptText="Oeuvre" maxWidth="Infinity"/>
            <HBox spacing="10.0">
                <Spinner fx:id="ratingSpinner" prefWidth="90.0"/>
                <TextField fx:id="commentField" promptText="Commentaire" HBox.hgrow="ALWAYS"/>
                <Button fx:id="addReviewButton" text="Publier" onAction="#handleAddReview"/>
            </HBox>
            <ListView fx:id="reviewList" VBox.vgrow="ALWAYS"/>
        </VBox>
    </HBox>
</VBox>
