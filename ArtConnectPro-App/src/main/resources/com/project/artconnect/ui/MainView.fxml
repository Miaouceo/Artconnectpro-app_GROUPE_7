<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.MainController">
    <MenuBar>
        <Menu text="File">
            <MenuItem text="Exit" onAction="#handleExit"/>
        </Menu>
        <Menu text="Help">
            <MenuItem text="About"/>
        </Menu>
    </MenuBar>

    <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: #f8fafc; -fx-border-color: #dbe4ee; -fx-border-width: 0 0 1 0;">
        <padding>
            <Insets bottom="10.0" left="14.0" right="14.0" top="10.0"/>
        </padding>
        <Label text="Role actif"/>
        <ComboBox fx:id="roleSelector" prefWidth="160.0"/>
        <Label fx:id="roleDescriptionLabel" style="-fx-text-fill: #24324f; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Visiteur: lecture seule | Membre: reservations, avis, profil | Artiste: oeuvres + ateliers | Admin: acces complet"/>
    </HBox>
    
    <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <Tab text="Discover">
            <fx:include source="DiscoverTab.fxml"/>
        </Tab>
        <Tab text="Artists">
            <fx:include source="ArtistsTab.fxml"/>
        </Tab>
        <Tab text="Artworks">
            <fx:include source="ArtworksTab.fxml"/>
        </Tab>
        <Tab text="Galleries">
            <fx:include source="GalleriesTab.fxml"/>
        </Tab>
        <Tab text="Exhibitions">
            <fx:include source="ExhibitionsTab.fxml"/>
        </Tab>
        <Tab text="Workshops">
            <fx:include source="WorkshopsTab.fxml"/>
        </Tab>
        <Tab text="Espace membre">
            <fx:include source="MemberSpaceTab.fxml"/>
        </Tab>
        <Tab text="Community">
            <fx:include source="CommunityTab.fxml"/>
        </Tab>
    </TabPane>
    
    <HBox alignment="CENTER_RIGHT" prefHeight="30.0" style="-fx-background-color: #f0f0f0;">
        <padding>
            <Insets right="10.0" left="10.0"/>
        </padding>
        <Label text="ArtConnect Pro v1.0 | Mode: In-Memory"/>
    </HBox>
</VBox>
